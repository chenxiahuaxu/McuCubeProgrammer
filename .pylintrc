[MASTER]
# Ignore flet - its API is too dynamic for pylint's static analysis
ignored-modules=flet

[MESSAGES CONTROL]
# Only disable what's truly unavoidable in this project's tech stack
disable=
    C0114,  # missing-module-docstring (tests)
    C0115,  # missing-class-docstring (tests)
    C0116,  # missing-function-docstring (tests)
    W0201,  # attribute-defined-outside-init (flet UI build() pattern)
    W0212,  # protected-access (tests + internal component usage)
    W0613,  # unused-argument (framework event callbacks)
    W0621,  # redefined-outer-name (pytest fixtures)
    W2301,  # unnecessary-ellipsis (abstract interface stubs)
    C0413,  # wrong-import-position (sys.path setup in main.py)
    C0415,  # import-outside-toplevel (lazy imports for optional deps)
    R0801,  # duplicate-code (flet UI border boilerplate across tabs)
    C0301,  # line-too-long (debug_tab visual alignment — see last comment in PR#X)

[FORMAT]
max-line-length=100

[DESIGN]
max-args=7
max-attributes=15
max-locals=20
max-branches=15
max-statements=60

[SIMILARITIES]
min-similarity-lines=5
ignore-comments=yes
ignore-docstrings=yes
ignore-imports=yes

[BASIC]
good-names=i,j,k,ex,_,e,fn,id,x,y
